# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but ship the reference template so users know what's configurable.
!.env.local.example

# vercel
.vercel

# local dashboard data (contains client PII once you connect real data)
/data/db.json
# automatic pre-migration backups of db.json (see src/lib/db.ts)
/data/db.json.bak-*
/data/deliverables/
/data/assets/
/data/branding/
/data/hawk-uploads/
/data/steward-uploads/
/data/digital-product-uploads/

# typescript
*.tsbuildinfo
next-env.d.ts
